# Copiar a .env y completar los valores

# Base de datos (por defecto SQLite local)
DATABASE_URL=sqlite:///sivml.db

# Para PostgreSQL (V2+):
# DATABASE_URL=postgresql+psycopg2://usuario:contraseña@localhost:5432/sivml

# OpenAI (V3+ — clasificación semántica con IA)
# OPENAI_API_KEY=sk-...

# Logging
LOG_LEVEL=INFO
